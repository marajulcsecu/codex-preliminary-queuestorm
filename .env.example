# QueueStorm Investigator - environment variables
PORT=8000
HOST=0.0.0.0

# Optional: enable Gemini 2.0 Flash AI enhancement of customer_reply and
# agent_summary text. If GEMINI_API_KEY is not set, the service falls back
# to deterministic rule-based templates. Never commit a real key to Git.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=4.0
