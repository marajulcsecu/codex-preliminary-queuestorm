# Example environment variables.
# DO NOT put real secrets here. Copy to .env locally if needed (gitignored).
# On Railway/Render: set real values via the platform env-var UI.

# Server port - the platform usually injects this automatically
PORT=8000

# Logging
LOG_LEVEL=INFO

# AI / API keys (only if we decide to use external models)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MODEL_NAME=
